# Set to "false" for live Yahoo Finance + Google News (100% free, no API key needed)
USE_MOCK_DATA=false

# OpenAI API Key — OPTIONAL. Only needed for advanced AI analysis.
# Without it, the app uses free rule-based analysis automatically.
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Secret for daily cron refresh (Vercel sets this automatically for cron jobs)
CRON_SECRET=your-random-secret-here
