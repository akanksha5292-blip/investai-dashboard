# OpenAI API Key (required for live AI analysis)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Model (optional, defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Set to "true" to use mock data instead of live APIs (works without API keys)
USE_MOCK_DATA=true

# Secret for daily cron refresh (Vercel sets this automatically for cron jobs)
CRON_SECRET=your-random-secret-here
